{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feedback Triage",
  "description": "Triaged feedback from feature requests, support tickets, reviews, NPS",
  "type": "object",
  "required": ["schema_version", "last_updated", "items"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "last_updated": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
    "sources_processed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "filename": { "type": "string" },
          "source_type": { "type": "string", "enum": ["feature_request", "support_ticket", "nps", "review", "survey", "slack", "other"] },
          "item_count": { "type": "integer", "minimum": 0 },
          "processed_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] }
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "summary"],
        "properties": {
          "id": { "type": "string" },
          "source": { "type": "string" },
          "category": { "type": "string", "enum": ["feature_request", "bug", "usability", "praise", "question", "out_of_scope"] },
          "summary": { "type": "string" },
          "original_text": { "type": "string" },
          "matched_theme_id": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
          "matched_jira_key": { "oneOf": [{ "type": "string" }, { "type": "null" }] },
          "frequency": { "type": "integer", "minimum": 1 },
          "revenue_signal": { "type": "string", "enum": ["none", "low", "medium", "high"] },
          "urgency": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "composite_score": { "type": "number", "minimum": 0 },
          "deduplicated_with": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_items": { "type": "integer" },
        "by_category": { "type": "object" },
        "top_themes": { "type": "array", "items": { "type": "string" } },
        "new_themes_detected": { "type": "array", "items": { "type": "string" } },
        "duplicates_merged": { "type": "integer" }
      }
    }
  }
}
