{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Customer Data Synthesis",
  "description": "Synthesized customer research: pain points, themes, feature candidates",
  "type": "object",
  "required": ["schema_version", "last_updated", "sources_processed", "themes"],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "last_updated": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
    "sources_processed": {
      "type": "object",
      "properties": {
        "interviews": { "type": "integer", "minimum": 0 },
        "nps_responses": { "type": "integer", "minimum": 0 },
        "support_tickets": { "type": "integer", "minimum": 0 },
        "surveys": { "type": "integer", "minimum": 0 },
        "analytics_reports": { "type": "integer", "minimum": 0 },
        "reviews": { "type": "integer", "minimum": 0 }
      }
    },
    "themes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "frequency", "intensity"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "pain_points": { "type": "array", "items": { "type": "string" } },
          "frequency": { "type": "integer", "minimum": 0 },
          "intensity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
          "segments_affected": { "type": "array", "items": { "type": "string" } },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "source": { "type": "string" },
                "quote": { "type": "string" },
                "count": { "type": "integer" }
              }
            }
          },
          "feature_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["title", "impact", "feasibility"],
              "properties": {
                "title": { "type": "string" },
                "impact": { "type": "string", "enum": ["low", "medium", "high"] },
                "feasibility": { "type": "string", "enum": ["XS", "S", "M", "L", "XL"] },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "supporting_evidence_count": { "type": "integer" }
              }
            }
          }
        }
      }
    },
    "jtbd_map": { "type": "array" },
    "contradictions": { "type": "array" },
    "segment_profiles": { "type": "array" }
  }
}
